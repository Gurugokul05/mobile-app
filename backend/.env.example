# Database
MONGO_URI=mongodb://localhost:27017/roots

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Server Port
PORT=5000
NODE_ENV=development

# Comma-separated allowed origins in production.
# Example: https://admin.roots.com,https://roots.com
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:8081

# Seed demo data on startup (disabled by default)
SEED_ON_STARTUP=false

# Razorpay (Optional for testing)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Cloudinary (Optional for image uploads)
USE_CLOUDINARY=false
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# SMTP (Required for OTP email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Roots <your_email@gmail.com>

# SMTP diagnostics endpoint (optional, dev-only)
ALLOW_SMTP_DIAGNOSTICS=false
SMTP_DIAGNOSTIC_KEY=replace_with_a_strong_secret
